    <script src="/scripts/site.js" defer></script>

    <script>
      // Client-side pagination: 8 cards per page.
      const PAGE_SIZE = 8;
      const grid = document.querySelector("[data-news-grid]");
      const cards = grid
        ? Array.from(grid.querySelectorAll<HTMLElement>(".news-card"))
        : [];
      const prev =
        document.querySelector<HTMLButtonElement>("[data-news-prev]");
      const next =
        document.querySelector<HTMLButtonElement>("[data-news-next]");
      const status = document.querySelector("[data-news-status]");
      const pages = Math.max(1, Math.ceil(cards.length / PAGE_SIZE));
      let page = 0;

      // Restore the saved page only when returning from an article
      // (the article's back link carries ?from=article). Any other entry —
      // nav menu, direct URL — always starts on page 1.
      const fromArticle = new URLSearchParams(location.search).has("from");
      if (fromArticle) {
        const saved = Number(sessionStorage.getItem("lisheng-news-page"));
        if (Number.isFinite(saved) && saved > 0 && saved < pages) page = saved;
        history.replaceState(null, "", "/news/");
      } else {
        sessionStorage.removeItem("lisheng-news-page");
      }

      const render = () => {
        cards.forEach((card, i) => {
          card.hidden = i < page * PAGE_SIZE || i >= (page + 1) * PAGE_SIZE;
        });
        if (status) status.textContent = `${page + 1} / ${pages}`;
        if (prev) prev.disabled = page === 0;
        if (next) next.disabled = page === pages - 1;
        // Lock the grid to its tallest rendered height (grow-only) so a
        // shorter last page can't shrink the document and shift the scroll.
        if (grid instanceof HTMLElement) {
          const h = grid.offsetHeight;
          const locked = parseFloat(grid.style.minHeight) || 0;
          if (h > locked) grid.style.minHeight = `${h}px`;
        }
      };

      const goTo = (target: number) => {
        const clamped = Math.max(0, Math.min(target, pages - 1));
        if (clamped === page) return;
        page = clamped;
        sessionStorage.setItem("lisheng-news-page", String(page));
        render();
      };

      prev?.addEventListener("click", () => goTo(page - 1));
      next?.addEventListener("click", () => goTo(page + 1));
      render();
    </script>
