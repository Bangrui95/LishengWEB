---
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import "../../styles/global.css";
import "../../styles/subpage.css";
import "../../styles/customization.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Product Customization | Lisheng Group</title>
    <meta
      name="description"
      content="Build your custom noodle product step by step: raw materials, formula, shape, sampling, quality standards, volume, packaging and export terms."
    />
  </head>
  <body>
    <Header />

    <main>
      <section class="page-hero" aria-labelledby="customization-hero-title">
        <img
          src="/images/main/products.png"
          alt="Custom noodle products developed by Lisheng"
        />
        <div class="page-hero-overlay"></div>
        <div class="page-hero-inner">
          <p class="page-kicker">Built to Your Specification</p>
          <h1 id="customization-hero-title">Product Customization</h1>
          <p class="page-hero-copy">
            Walk through nine steps, pick what fits your market, and send us
            your product brief — we engineer the rest.
          </p>
        </div>
      </section>

      <section class="page-section" aria-labelledby="config-title">
        <div class="page-section-inner">
          <p class="config-kicker">Build your product brief</p>
          <h2 id="config-title">Configure your noodle program</h2>
          <p>
            Every option below is a real capability of our plants. Select what
            you need at each step — skip anything you are not sure about, our
            team will advise.
          </p>

          <!-- STEP 01 -->
          <div class="config-step">
            <span class="config-step-num">STEP 01</span>
            <h3>Export Market</h3>
            <p>
              Where will this product sell? Your markets guide our
              recommendations on compliance, formats and flavour direction —
              pick all that apply.
            </p>
            <div class="config-options" data-config-group>
              <button type="button">Southeast Asia</button>
              <button type="button">East Asia (Japan / Korea)</button>
              <button type="button">Europe</button>
              <button type="button">North America</button>
              <button type="button">South America</button>
              <button type="button">Middle East &amp; Africa</button>
              <button type="button">Oceania</button>
              <button type="button">Multiple / Other Markets</button>
            </div>
          </div>

          <!-- STEP 02 -->
          <div class="config-step">
            <span class="config-step-num">STEP 02</span>
            <h3>Product Type</h3>
            <p>
              Choose the base product your brand needs — Chinese classics or
              international styles, all from the same wheat expertise.
            </p>
            <div class="config-options" data-config-group>
              <button type="button">Chinese Dried Noodles</button>
              <button type="button">Ramen Style</button>
              <button type="button">Udon Style</button>
              <button type="button">Soba / Buckwheat Style</button>
              <button type="button">Spaghetti Style</button>
              <button type="button">Non-Fried Instant Noodles</button>
              <button type="button">Noodle Sheets</button>
              <button type="button">Regional Chinese Series</button>
              <button type="button">Custom Product Type</button>
            </div>
          </div>

          <!-- STEP 03 -->
          <div class="config-step">
            <span class="config-step-num">STEP 03</span>
            <h3>Raw Material</h3>
            <p>
              Pick a flour base by positioning — from economical everyday lines
              to premium and health-focused ranges ($ = indicative price tier).
            </p>
            <div class="config-options" data-config-group>
              <button type="button">Standard Wheat Flour $</button>
              <button type="button">Wheat-Core Flour $$</button>
              <button type="button">High-Gluten Flour $$</button>
              <button type="button">Whole Wheat Flour $$$</button>
              <button type="button">Multigrain Blend $$$</button>
              <button type="button">Specify Your Own Material</button>
            </div>
          </div>

          <!-- STEP 04 -->
          <div class="config-step">
            <span class="config-step-num">STEP 04</span>
            <h3>Formula Direction</h3>
            <p>
              Tell us the eating experience your market expects — or bring your
              own recipe and we engineer it for industrial production.
            </p>
            <div class="config-options" data-config-group>
              <button type="button">Chewy &amp; Springy (East Asia)</button>
              <button type="button">Soft &amp; Quick-Cooking</button>
              <button type="button">Pasta-Style Firm (Al Dente)</button>
              <button type="button">High-Fibre Whole Grain</button>
              <button type="button">Egg-Enriched</button>
              <button type="button">Vegetable Blend</button>
              <button type="button">Use My Own Recipe</button>
            </div>
          </div>

          <!-- STEP 05 -->
          <div class="config-step">
            <span class="config-step-num">STEP 05</span>
            <h3>Shape &amp; Size</h3>
            <p>
              Cut width, profile and length — Chinese cut numbers with their
              closest Western pasta equivalents.
            </p>
            <div class="config-options" data-config-group>
              <button type="button">Extra-Fine Round (0# / Angel Hair)</button>
              <button type="button">Fine Round (2# / Spaghetti)</button>
              <button type="button">Medium (3# / Linguine)</button>
              <button type="button">Wide Flat (6# / Fettuccine)</button>
              <button type="button">Knife-Cut Wide (10# / Pappardelle)</button>
              <button type="button">Custom Size</button>
            </div>
          </div>

          <!-- STEP 06 -->
          <div class="config-step">
            <span class="config-step-num">STEP 06</span>
            <h3>Sample Testing</h3>
            <p>Validate the product before any volume commitment.</p>
            <div class="config-options" data-config-group>
              <button type="button">International Sample Delivery</button>
              <button type="button">Video Sample Review</button>
              <button type="button">Factory Visit &amp; Audit</button>
            </div>
          </div>

          <!-- STEP 07 -->
          <div class="config-step">
            <span class="config-step-num">STEP 07</span>
            <h3>Quality &amp; Certification</h3>
            <p>
              Select every standard your product must meet — multiple choices
              welcome.
            </p>
            <div class="config-options" data-config-group>
              <button type="button">ISO 9001 / 22000 / HACCP (Base)</button>
              <button type="button">EU Market Compliance</button>
              <button type="button">US Market Compliance</button>
              <button type="button">Halal Requirements</button>
              <button type="button">Third-Party Lab Testing</button>
              <button type="button">Customer-Specified Standard</button>
            </div>
          </div>

          <!-- STEP 08 -->
          <div class="config-step">
            <span class="config-step-num">STEP 08</span>
            <h3>Volume &amp; Schedule</h3>
            <p>
              An order rhythm that fits your channel — start small, scale on
              our reserve capacity.
            </p>
            <div class="config-options" data-config-group>
              <button type="button">Trial Order (≤ 1 Container)</button>
              <button type="button">Monthly Container Supply</button>
              <button type="button">Quarterly Program</button>
              <button type="button">Annual Frame Agreement</button>
              <button type="button">Not Sure Yet</button>
            </div>
          </div>

          <!-- STEP 09 -->
          <div class="config-step">
            <span class="config-step-num">STEP 09</span>
            <h3>Packaging &amp; Export</h3>
            <p>
              Pick a pack format for your channel, then tell us how you want
              the goods moved.
            </p>
            <p class="config-group-label">Packaging format</p>
            <div class="config-options" data-config-group>
              <button type="button">Retail Pillow Pack</button>
              <button type="button">Paper-Wrapped Bundle</button>
              <button type="button">Family Pack with Handle</button>
              <button type="button">Foodservice Bulk Carton</button>
              <button type="button">Fully Custom Packaging</button>
            </div>
            <p class="config-group-label">Export terms</p>
            <div class="config-options" data-config-group>
              <button type="button">We Deliver to Your Port (CIF)</button>
              <button type="button">You Arrange Freight (FOB)</button>
              <button type="button">Ex-Factory Pickup (EXW)</button>
              <button type="button">Need Advice</button>
            </div>
          </div>

          <!-- Save & contact -->
          <div class="config-save">
            <div>
              <h2>Happy with your configuration?</h2>
              <p>
                Send it to our export team — we reply with samples direction,
                specifications and a quotation path.
              </p>
            </div>
            <a class="config-save-link" href="/contact/">
              Save &amp; Send Inquiry <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer showCta={false} />
    <script src="/scripts/site.js" defer></script>

    <script>
      // Option selection: every group is multi-select.
      // Click toggles a button on/off. No data is stored yet.
      document.querySelectorAll("[data-config-group] button").forEach((btn) => {
        btn.addEventListener("click", () => {
          btn.classList.toggle("selected");
        });
      });
    </script>
  </body>
</html>
