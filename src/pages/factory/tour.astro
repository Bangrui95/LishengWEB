---
import ContactCta from "../../components/ContactCta.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import "../../styles/global.css";
import "../../styles/subpage.css";
import "../../styles/factory-tour.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Factory Tour | Visit Lisheng Group in China</title>
    <meta
      name="description"
      content="Visit Lisheng's noodle and flour plants in Shandong, China: see intelligent production lines, meet the R&D team, audit our quality systems — and explore Confucius's hometown."
    />
  </head>
  <body>
    <Header />

    <main>
      <section class="page-hero" aria-labelledby="tour-hero-title">
        <img
          src="/images/factory/01.png"
          alt="Visitors touring a Lisheng production facility"
        />
        <div class="page-hero-overlay"></div>
        <div class="page-hero-inner">
          <p class="page-kicker">Visit Lisheng</p>
          <h1 id="tour-hero-title">Factory Tour</h1>
          <p class="page-hero-copy">
            The fastest way to trust a manufacturer is to walk its production
            floor. Come to Jining — see the lines, meet the team, taste the
            product.
          </p>
        </div>
      </section>

      <!-- Why visit -->
      <section class="page-section" aria-labelledby="tour-why-title">
        <div class="page-section-inner">
          <p class="tour-kicker">Why visit</p>
          <h2 id="tour-why-title">Seeing is believing</h2>
          <p>
            Lisheng has welcomed distributors, partners and government
            delegations to its plants for over a decade. For overseas buyers, a
            visit answers in one day what months of emails cannot.
          </p>

          <div class="tour-reasons">
            <article class="tour-reason">
              <h3>Verify Before You Order</h3>
              <p>
                Walk the milling floors and noodle lines, check hygiene and
                processes with your own eyes, and audit our quality systems on
                site — we have nothing to hide.
              </p>
            </article>
            <article class="tour-reason">
              <h3>Learn &amp; Exchange</h3>
              <p>
                Sit down with our R&amp;D lab and production engineers. Bring
                your product questions — taste samples together and refine your
                specification face to face.
              </p>
            </article>
            <article class="tour-reason">
              <h3>Understand Chinese Manufacturing</h3>
              <p>
                See how a national key leading enterprise runs grain storage,
                intelligent milling and export packing in one chain — a window
                into modern Chinese food manufacturing.
              </p>
            </article>
          </div>
        </div>
      </section>

      <!-- What you'll see -->
      <section class="page-section alt" aria-labelledby="tour-stops-title">
        <div class="page-section-inner">
          <p class="tour-kicker">On the route</p>
          <h2 id="tour-stops-title">What you'll see</h2>

          <dl class="tour-stops">
            <div>
              <dt>Intelligent Milling Floor</dt>
              <dd>
                Bühler milling systems under PLC and MES control — the flagship
                Liangshan plant runs largely unmanned.
              </dd>
            </div>
            <div>
              <dt>Automated Noodle Lines</dt>
              <dd>
                1000-type lines covering dough feeding, cutting, drying and
                packing, with solar-heated drying rooms.
              </dd>
            </div>
            <div>
              <dt>R&amp;D Laboratory</dt>
              <dd>
                Where formulas are tested and tuned — including the
                stone-milled whole grain workshop.
              </dd>
            </div>
            <div>
              <dt>Packaging Workshop</dt>
              <dd>
                The group's in-house packaging resources behind private label
                artwork and flexible formats.
              </dd>
            </div>
            <div>
              <dt>Grain Storage</dt>
              <dd>
                Variety-by-variety wheat storage feeding 200,000 tons of
                capacity — quality control starts here.
              </dd>
            </div>
            <div>
              <dt>Product Tasting</dt>
              <dd>
                Cook and compare product samples with our team, from classic
                dried noodles to multigrain lines.
              </dd>
            </div>
          </dl>
        </div>
      </section>

      <!-- A typical visit -->
      <section class="page-section" aria-labelledby="tour-day-title">
        <div class="page-section-inner">
          <p class="tour-kicker">A typical visit</p>
          <h2 id="tour-day-title">How a visit day runs</h2>

          <ol class="tour-flow">
            <li>
              <h3>Welcome &amp; Introduction</h3>
              <p>
                Company overview at our Jining headquarters — history, bases,
                capacity and export programs.
              </p>
            </li>
            <li>
              <h3>Plant Tour</h3>
              <p>
                Guided walk through milling, noodle production, packaging and
                grain storage, with engineers on hand.
              </p>
            </li>
            <li>
              <h3>Tasting &amp; Sample Review</h3>
              <p>
                Cook samples together, compare textures and review product
                specifications for your market.
              </p>
            </li>
            <li>
              <h3>Technical Exchange</h3>
              <p>
                Q&amp;A with R&amp;D and quality teams — formulas, standards,
                certifications and your custom requirements.
              </p>
            </li>
            <li>
              <h3>Business Discussion</h3>
              <p>
                Sit down with the export team on volumes, packaging, terms and
                a practical cooperation path.
              </p>
            </li>
            <li>
              <h3>Culture Trip (Optional)</h3>
              <p>
                Jining is the hometown of Confucius — we are glad to arrange a
                side trip to nearby Qufu, as we have for partners for years.
              </p>
            </li>
          </ol>
        </div>
      </section>

      <!-- Practical info -->
      <section class="page-section alt" aria-labelledby="tour-info-title">
        <div class="page-section-inner">
          <div class="tour-split" style="margin-top: 0;">
            <div class="tour-split-media">
              <img
                src="/images/main/2.jpg"
                alt="Lisheng headquarters in Jining, Shandong"
              />
            </div>
            <div class="tour-split-copy">
              <p class="tour-kicker">Practical information</p>
              <h3 id="tour-info-title">Getting here is easy</h3>
              <p>
                Our headquarters sits in the Jining High-tech Industrial
                Development Zone, Shandong Province — about 40 minutes from
                Qufu East high-speed rail station, with direct trains from
                Beijing (≈2.5 h) and Shanghai (≈3.5 h).
              </p>
              <p>
                Tell us your dates and interests, and we will plan the rest —
                most visits run comfortably in a single day, or two days with
                multiple plants.
              </p>
              <ul class="tour-support" aria-label="What we arrange">
                <li>Visit invitation letter</li>
                <li>Station &amp; airport pickup</li>
                <li>English interpreter</li>
                <li>Tailored itinerary</li>
                <li>Multi-plant routes</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <ContactCta
        kicker="Plan your visit"
        title="Tell us when you're coming — we'll prepare the rest."
        text="Share your travel window and what you want to see. Our export team confirms the itinerary, arranges pickup and books the product tasting."
        buttonLabel="Book a Factory Tour"
        buttonHref="/contact/"
      />
    </main>

    <Footer showCta={false} />
    <script src="/scripts/site.js" defer></script>
  </body>
</html>
