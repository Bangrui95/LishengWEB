---
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import "../../styles/global.css";
import "../../styles/subpage.css";
import "../../styles/factory-certificates.css";

const CERT = "/images/factory/certificates/certificate";
const GREEN = "/images/factory/certificates/green";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Certificates &amp; Awards | Lisheng Group</title>
    <meta
      name="description"
      content="Lisheng Group certifications: ISO 9001, ISO 22000 and HACCP with IQNET international recognition, Green Food A-grade products, China Top-Brand Product and industry awards."
    />
  </head>
  <body>
    <Header />

    <main>
      <section class="page-hero" aria-labelledby="cert-hero-title">
        <img src="/images/main/3.jpg" alt="Lisheng certificates and quality awards" />
        <div class="page-hero-overlay"></div>
        <div class="page-hero-inner">
          <p class="page-kicker">Quality &amp; Recognition</p>
          <h1 id="cert-hero-title">Certificates</h1>
          <p class="page-hero-copy">
            Management system certifications, national brand recognition and
            industry awards earned over three decades of food manufacturing.
          </p>
        </div>
      </section>

      <!-- National recognition -->
      <section class="page-section" aria-labelledby="cert-national-title">
        <div class="page-section-inner">
          <p class="company-kicker">National recognition</p>
          <h2 id="cert-national-title">Recognised at the national level</h2>

          <dl class="machine-grid">
            <div>
              <dt>China Top-Brand Product (2007)</dt>
              <dd>
                “Lisheng” wheat flour was awarded the national Top-Brand
                Product title.
              </dd>
            </div>
            <div>
              <dt>China Famous Trademark (2011)</dt>
              <dd>
                The Lisheng trademark received China's highest trademark
                recognition.
              </dd>
            </div>
            <div>
              <dt>Key Leading Enterprise in Agricultural Industrialisation</dt>
              <dd>
                Recognised as a key leading enterprise in agricultural
                industrialisation (2010).
              </dd>
            </div>
            <div>
              <dt>Green Food &amp; Pollution-Free Certifications</dt>
              <dd>
                Selected products carry China's Green Food certification, the
                national Pollution-Free Agricultural Product mark and the
                “Reliable Grain &amp; Oil” designation.
              </dd>
            </div>
          </dl>
        </div>
      </section>

      <!-- Industry awards -->
      <section class="page-section" aria-labelledby="cert-awards-title">
        <div class="page-section-inner">
          <p class="company-kicker">Industry awards</p>
          <h2 id="cert-awards-title">Standing in the industry</h2>

          <dl class="machine-grid">
            <div>
              <dt>China Top 50 Wheat Flour Processors</dt>
              <dd>
                Ranked among China's top 50 wheat flour processing enterprises
                for five consecutive years.
              </dd>
            </div>
            <div>
              <dt>Most Competitive Brand (2019)</dt>
              <dd>
                Awarded by the grain &amp; oil marketing branch of the Chinese
                Cereals and Oils Association.
              </dd>
            </div>
            <div>
              <dt>Shandong Top 10 Grain &amp; Oil Brands</dt>
              <dd>
                Listed among the top ten flour industry brands in Shandong
                Province; “Lisheng” is a Shandong Famous Trademark.
              </dd>
            </div>
            <div>
              <dt>Food Safety Integrity Unit</dt>
              <dd>
                Recognised as a Shandong Province food safety integrity unit
                and high-tech enterprise.
              </dd>
            </div>
          </dl>

          <div class="company-cta">
            <div>
              <h2>Need compliance details for your market?</h2>
              <p>
                Ask us for certificate copies, specifications and export
                documentation for your import requirements.
              </p>
            </div>
            <a class="company-cta-link" href="/contact/">
              Contact Us <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </section>

      <!-- Management systems -->
      <section class="page-section alt" aria-labelledby="cert-systems-title">
        <div class="page-section-inner">
          <p class="company-kicker">Management systems</p>
          <h2 id="cert-systems-title">Certified food safety management</h2>
          <p>
            Lisheng has operated under certified management systems since 2003.
            Quality, food safety and HACCP certifications are issued by CQC
            (China Quality Certification Centre), carry IQNET international
            recognition and are re-audited on a regular cycle. Click any
            certificate to view the original PDF.
          </p>

          <div class="cert-grid" aria-label="Management system certificates">
            <div class="cert-card">
              <a class="cert-media" href={`${CERT}/iso9001-en.pdf`} target="_blank" rel="noopener">
                <img src={`${CERT}/iso9001-en-preview.jpg`} alt="ISO 9001:2015 quality management system certificate issued by CQC" loading="lazy" />
              </a>
              <h3>ISO 9001:2015</h3>
              <p>Quality management system — dried noodles and wheat flour</p>
            </div>
            <div class="cert-card">
              <a class="cert-media" href={`${CERT}/iso22000-en.pdf`} target="_blank" rel="noopener">
                <img src={`${CERT}/iso22000-en-preview.jpg`} alt="ISO 22000:2018 food safety management system certificate issued by CQC" loading="lazy" />
              </a>
              <h3>ISO 22000:2018</h3>
              <p>Food safety management system covering flour and noodle production</p>
            </div>
            <div class="cert-card">
              <a class="cert-media" href={`${CERT}/haccp-en.pdf`} target="_blank" rel="noopener">
                <img src={`${CERT}/haccp-en-preview.jpg`} alt="HACCP system certificate issued by CQC" loading="lazy" />
              </a>
              <h3>HACCP</h3>
              <p>Hazard analysis &amp; critical control points</p>
            </div>
            <div class="cert-card">
              <a class="cert-media" href={`${CERT}/iso9001-iqnet-en.pdf`} target="_blank" rel="noopener">
                <img src={`${CERT}/iqnet-preview.jpg`} alt="IQNET international certificate recognising Lisheng's ISO 9001 management system" loading="lazy" />
              </a>
              <h3>IQNET International</h3>
              <p>IQNET international certificate for ISO 9001 &amp; ISO 22000</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Green Food certification -->
      <section class="page-section alt has-divider" aria-labelledby="cert-green-title">
        <div class="page-section-inner">
          <p class="company-kicker">Green Food</p>
          <h2 id="cert-green-title">Green Food A-grade certified products</h2>
          <p>
            Five Lisheng products are certified Green Food A-grade by the China
            Green Food Development Center — China's strictest national standard
            for residue-controlled, traceable food. Current certificates are
            valid through August 2026.
          </p>

          <div class="green-grid" aria-label="Green Food certificates">
            <figure class="green-card">
              <a href={`${GREEN}/green-super-refined-flour.jpg`} target="_blank" rel="noopener">
                <img src={`${GREEN}/green-super-refined-flour.jpg`} alt="Green Food A-grade certificate for super-grade refined wheat flour" loading="lazy" />
              </a>
              <figcaption>Super-Grade Refined Flour</figcaption>
            </figure>
            <figure class="green-card">
              <a href={`${GREEN}/green-wheat-core-flour.jpg`} target="_blank" rel="noopener">
                <img src={`${GREEN}/green-wheat-core-flour.jpg`} alt="Green Food A-grade certificate for multi-purpose wheat core flour" loading="lazy" />
              </a>
              <figcaption>Multi-Purpose Wheat Core Flour</figcaption>
            </figure>
            <figure class="green-card">
              <a href={`${GREEN}/green-dragon-beard-noodles.jpg`} target="_blank" rel="noopener">
                <img src={`${GREEN}/green-dragon-beard-noodles.jpg`} alt="Green Food A-grade certificate for premium dragon-beard noodles" loading="lazy" />
              </a>
              <figcaption>Premium Dragon-Beard Noodles</figcaption>
            </figure>
            <figure class="green-card">
              <a href={`${GREEN}/green-egg-noodles.jpg`} target="_blank" rel="noopener">
                <img src={`${GREEN}/green-egg-noodles.jpg`} alt="Green Food A-grade certificate for premium egg noodles" loading="lazy" />
              </a>
              <figcaption>Premium Egg Noodles</figcaption>
            </figure>
            <figure class="green-card">
              <a href={`${GREEN}/green-original-noodles.jpg`} target="_blank" rel="noopener">
                <img src={`${GREEN}/green-original-noodles.jpg`} alt="Green Food A-grade certificate for premium original noodles" loading="lazy" />
              </a>
              <figcaption>Premium Original Noodles</figcaption>
            </figure>
          </div>
        </div>
      </section>


    </main>

    <Footer />
    <script src="/scripts/site.js" defer></script>
  </body>
</html>
