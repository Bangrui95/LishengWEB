---
import ContactCta from "../components/ContactCta.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import "../styles/global.css";
import "../styles/subpage.css";
import "../styles/services.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>OEM Noodle Manufacturing Services | Lisheng Group</title>
    <meta
      name="description"
      content="OEM and private label noodle manufacturing: in-house R&D with custom formulation, national-grade grain sourcing, and 600 tons of daily capacity for stable export supply."
    />
  </head>
  <body>
    <Header />

    <main>
      <section class="page-hero" aria-labelledby="services-hero-title">
        <img
          src="/images/main/OEM.png"
          alt="OEM noodle manufacturing and packaging at Lisheng"
        />
        <div class="page-hero-overlay"></div>
        <div class="page-hero-inner">
          <p class="page-kicker">OEM &amp; Private Label</p>
          <h1 id="services-hero-title">Noodle Contract Manufacturing</h1>
          <p class="page-hero-copy">
            Your brand, our factory. Custom-formulated dried noodles produced
            at national-enterprise scale and supplied export-ready, on
            schedule.
          </p>
          <div class="services-hero-actions">
            <a class="services-hero-primary" href="/contact/">
              Start an OEM Project <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </section>

      <!-- OEM workflow -->
      <section class="page-section" aria-labelledby="services-flow-title">
        <div class="page-section-inner">
          <p class="services-kicker">From inquiry to container</p>
          <h2 id="services-flow-title">How an OEM project runs</h2>

          <ol class="oem-flow">
            <li>
              <h3>Inquiry &amp; Consultation</h3>
              <p>
                Share your target market, product idea, volume plan and
                packaging direction. We confirm feasibility and direction.
              </p>
            </li>
            <li>
              <h3>Formula &amp; Sampling</h3>
              <p>
                Our R&amp;D lab develops the recipe and sends samples until
                taste, texture and specification are approved.
              </p>
            </li>
            <li>
              <h3>Quotation &amp; Agreement</h3>
              <p>
                A clear quote based on formula, pack format, order volume and
                delivery terms — then the manufacturing agreement.
              </p>
            </li>
            <li>
              <h3>Artwork &amp; Trial Order</h3>
              <p>
                In-house packaging finalises your artwork; a trial run
                validates the product on the production line.
              </p>
            </li>
            <li>
              <h3>Mass Production &amp; QC</h3>
              <p>
                Automated lines produce at scale under ISO 22000 / HACCP
                control, with batch testing from raw wheat to finished pack.
              </p>
            </li>
            <li>
              <h3>Export &amp; Delivery</h3>
              <p>
                Container loading, export documentation and logistics support
                to your port — with a stable schedule for repeat orders.
              </p>
            </li>
          </ol>
        </div>
      </section>

      <!-- Three pillars -->
      <section class="page-section tight-top" aria-labelledby="services-pillars-title">
        <div class="page-section-inner">
          <p class="services-kicker">Why brands manufacture with Lisheng</p>
          <h2 id="services-pillars-title">
            Three guarantees behind every order
          </h2>

          <div class="pillar-grid">
            <article class="pillar-card">
              <span class="pillar-num">01</span>
              <h3>In-House R&amp;D, Custom Formulation</h3>
              <p>
                Our own product development system turns your brief into a
                production-ready recipe — formula ratios included.
              </p>
              <ul>
                <li>Custom flour blends and ingredient ratios</li>
                <li>Noodle texture, thickness and cooking-time tuning</li>
                <li>10+ food production invention patents</li>
                <li>Lab-tested with Perten grain analysis instruments</li>
              </ul>
            </article>

            <article class="pillar-card">
              <span class="pillar-num">02</span>
              <h3>National-Grade Grain Assurance</h3>
              <p>
                A national key leading enterprise in agricultural
                industrialisation, with priority access to premium wheat
                quotas.
              </p>
              <ul>
                <li>Bases inside China's premium wheat regions</li>
                <li>170,000-mu contracted wheat base, 18,000 farm households</li>
                <li>200,000 tons of own grain storage</li>
                <li>ISO 9001 / ISO 22000 / HACCP certified production</li>
              </ul>
            </article>

            <article class="pillar-card">
              <span class="pillar-num">03</span>
              <h3>Capacity for Stable Export</h3>
              <p>
                Six production bases keep volume in reserve, so your supply
                stays steady as your brand grows.
              </p>
              <ul>
                <li>600 tons of dried noodles per day, group-wide</li>
                <li>7 automated 1000-type noodle production lines</li>
                <li>In-house packaging for fast artwork turnaround</li>
                <li>Export documentation support for overseas orders</li>
              </ul>
            </article>
          </div>
        </div>
      </section>

      <!-- What you can customise -->
      <section class="page-section alt" aria-labelledby="services-custom-title">
        <div class="page-section-inner">
          <p class="services-kicker">Built to your specification</p>
          <h2 id="services-custom-title">What you can customise</h2>

          <div class="custom-grid">
            <div class="custom-item">
              <h3>Formula &amp; Ratio</h3>
              <p>
                Flour blend, protein level, egg or vegetable content, multigrain
                ratios — adjusted to your recipe or developed from scratch.
              </p>
            </div>
            <div class="custom-item">
              <h3>Shape &amp; Cut</h3>
              <p>
                From extra-fine dragon beard to wide knife-cut styles, round or
                flat, plus noodle sheets and regional formats.
              </p>
            </div>
            <div class="custom-item">
              <h3>Texture &amp; Cooking Time</h3>
              <p>
                Elasticity, firmness and boiling behaviour tuned for your
                market's preparation habits.
              </p>
            </div>
            <div class="custom-item">
              <h3>Packaging Format</h3>
              <p>
                Pillow pack, paper-wrapped bundle, family pack with handle,
                bulk foodservice carton — with your artwork.
              </p>
            </div>
            <div class="custom-item">
              <h3>Pack Weight &amp; Carton</h3>
              <p>
                Net weights from 150 g to 4 kg and carton configurations
                matched to your retail or wholesale channel.
              </p>
            </div>
            <div class="custom-item">
              <h3>Regional Styles</h3>
              <p>
                Proven OEM programs for Yangchun, ramen, dandan, hot-dry and
                other regional Chinese noodle styles.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Production journey: vertical timeline (overview only — detail page to follow) -->
      <section class="page-section" aria-labelledby="services-journey-title">
        <div class="page-section-inner">
          <p class="services-kicker">Production journey</p>
          <h2 id="services-journey-title">From raw wheat to your port</h2>

          <ol class="prod-timeline">
            <li>
              <span class="prod-step-num">STEP 01</span>
              <h3>Raw Material Selection</h3>
              <p>
                Premium wheat from contracted bases in national wheat regions,
                tested and stored by variety before intake.
              </p>
            </li>
            <li>
              <span class="prod-step-num">STEP 02</span>
              <h3>Formula &amp; Ratio</h3>
              <p>
                Recipes developed in our own R&amp;D laboratory — fully custom
                ingredient ratios supported.
              </p>
            </li>
            <li>
              <span class="prod-step-num">STEP 03</span>
              <h3>Size &amp; Shape Customisation</h3>
              <p>
                Cut, width and thickness shaped to order, across different
                regional noodle styles.
              </p>
            </li>
            <li>
              <span class="prod-step-num">STEP 04</span>
              <h3>Custom Packaging Design</h3>
              <p>
                Pack format and artwork produced with the group's in-house
                packaging resources.
              </p>
            </li>
            <li>
              <span class="prod-step-num">STEP 05</span>
              <h3>Quality Inspection</h3>
              <p>
                Batch testing from flour to finished pack under ISO 22000 and
                HACCP control.
              </p>
            </li>
            <li>
              <span class="prod-step-num">STEP 06</span>
              <h3>Export &amp; Shipping</h3>
              <p>
                Container loading, export documentation and on-schedule
                delivery to your port.
              </p>
            </li>
          </ol>
        </div>
      </section>

      <!-- Company strength: raw material / R&D / nationwide plants -->
      <section class="page-section tight-top" aria-label="Why Lisheng delivers">
        <div class="page-section-inner">
          <div class="services-split">
            <div class="services-split-media">
              <img
                src="/images/factory/02.png"
                alt="Wheat quality inspection and milling at Lisheng"
              />
            </div>
            <div class="services-split-copy">
              <p class="services-kicker">Raw material assurance</p>
              <h3 id="services-quality-title">
                Quality starts in the wheat field
              </h3>
              <p>
                Every Lisheng base sits inside a national premium wheat
                production area. Through our “company + base + farmer” model we
                contract 170,000 mu of wheat with unified seed, planting and
                purchasing — so the grain entering our mills is known before
                it arrives.
              </p>
              <p>
                Incoming wheat is tested and stored by variety, blended to
                order, and milled at low temperature. As a national key
                leading enterprise, Lisheng holds priority quotas for premium
                grain — your product is never short of good wheat.
              </p>
            </div>
          </div>

          <div class="services-split reverse">
            <div class="services-split-media">
              <img
                src="/images/factory/11.png"
                alt="Lisheng R&D laboratory and product development"
              />
            </div>
            <div class="services-split-copy">
              <p class="services-kicker">In-house R&amp;D</p>
              <h3 id="services-rd-title">A lab that owns the recipe</h3>
              <p>
                Lisheng runs an independent product development system covering
                raw material testing, formula adjustment, noodle texture
                development and packaging trials — your product is engineered,
                not improvised.
              </p>
              <p>
                The group holds <strong>10+ food production invention
                patents</strong>, and its latest innovation — a Danish
                stone-milled whole grain line with low-temperature grinding and
                bran baking — shows how far the lab takes a recipe.
              </p>
              <a class="services-split-link" href="/factory/lab/">
                Visit the Product Lab
              </a>
            </div>
          </div>

          <div class="services-split">
            <div class="services-split-media">
              <img
                src="/images/factory/03.png"
                alt="Automated noodle production lines at a Lisheng plant"
              />
            </div>
            <div class="services-split-copy">
              <p class="services-kicker">Factory production capacity</p>
              <h3 id="services-network-title">
                Automated plants across China
              </h3>
              <p>
                Six production bases span Shandong, Hebei and Henan — each
                built inside a premium wheat region, each running automated
                processing lines. Together they mill 4,500 tons of wheat and
                produce 600 tons of dried noodles every day.
              </p>
              <p>
                Seven 1000-type automated noodle lines cover dough feeding,
                cutting, drying and packing, anchored by the flagship Liangshan
                smart plant — so your order is never tied to a single
                factory's schedule.
              </p>
              <a class="services-split-link" href="/company/subsidiaries/">
                See our production bases
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Production environment & machinery -->
      <section class="page-section alt" aria-labelledby="services-equip-title">
        <div class="page-section-inner">
          <p class="services-kicker">Production environment</p>
          <h2 id="services-equip-title">Modern plants, intelligent lines</h2>
          <p>
            Your order runs on the same international-grade equipment trusted
            by the world's biggest mills — inside clean, purpose-built plants
            that welcome customer audits.
          </p>

          <dl class="equip-grid">
            <div>
              <dt>Bühler Intelligent Milling Systems</dt>
              <dd>
                Swiss Bühler equipment group-wide, including a fully intelligent
                flour line with complete blending at the Liangshan plant.
              </dd>
            </div>
            <div>
              <dt>Perten Grain Analysis Instruments</dt>
              <dd>
                Every batch of wheat and flour is profiled, so specifications
                stay measurable and repeatable order after order.
              </dd>
            </div>
            <div>
              <dt>MDDK Roller Mills, Five Purification Passes</dt>
              <dd>
                Gentle mid-route extraction protects protein and starch — high
                purity flour with nutrition intact.
              </dd>
            </div>
            <div>
              <dt>PLC + MES Unmanned Control</dt>
              <dd>
                From wheat intake to palletising, the flagship plant runs
                largely unmanned under remote intelligent control.
              </dd>
            </div>
            <div>
              <dt>Low-Temperature Milling</dt>
              <dd>
                Controlled milling temperature preserves vitamins and the
                wheat's natural aroma in every pack.
              </dd>
            </div>
            <div>
              <dt>Green Energy Production</dt>
              <dd>
                2 MW of rooftop solar and solar-heated drying rooms cut the
                footprint of every noodle we ship.
              </dd>
            </div>
          </dl>
          <a class="services-split-link" href="/factory/production/">
            Explore our production facilities
          </a>
        </div>
      </section>

      <!-- Certifications & export credentials -->
      <section class="page-section" aria-labelledby="services-cert-title">
        <div class="page-section-inner">
          <p class="services-kicker">Certified for global trade</p>
          <h2 id="services-cert-title">
            Credentials your import team can verify
          </h2>
          <p>
            Certified management systems, national brand recognition and
            export paperwork support — certificate copies are available for
            serious OEM inquiries.
          </p>

          <div class="cert-chip-grid">
            <div class="cert-chip">
              <h3>ISO 9001</h3>
              <p>Quality management system certification.</p>
            </div>
            <div class="cert-chip">
              <h3>ISO 22000</h3>
              <p>Food safety management system certification.</p>
            </div>
            <div class="cert-chip">
              <h3>HACCP</h3>
              <p>Hazard analysis &amp; critical control point system.</p>
            </div>
            <div class="cert-chip">
              <h3>ISO 14001</h3>
              <p>Environmental management system certification.</p>
            </div>
            <div class="cert-chip">
              <h3>China Green Food</h3>
              <p>
                Selected products carry China's Green Food certification and
                the Pollution-Free Agricultural Product mark.
              </p>
            </div>
            <div class="cert-chip">
              <h3>Export Documentation</h3>
              <p>
                Certificate of origin, health and inspection paperwork prepared
                to your destination market's requirements.
              </p>
            </div>
          </div>
          <a class="services-split-link" href="/factory/certificates/">
            View all certificates &amp; awards
          </a>
        </div>
      </section>

      <!-- Capacity & export -->
      <section class="page-section alt" aria-labelledby="services-capacity-title">
        <div class="page-section-inner">
          <p class="services-kicker">Capacity &amp; export readiness</p>
          <h2 id="services-capacity-title">
            Volume in reserve, supply on schedule
          </h2>
          <p>
            OEM programs fail when capacity runs out. Lisheng's six production
            bases run far below their ceiling, keeping room for your growth —
            and our export team handles documentation so containers leave on
            time, every time.
          </p>

          <div class="services-stats" aria-label="Capacity figures">
            <dl>
              <dt>600<span>Tons</span></dt>
              <dd>Dried noodles per day, group-wide</dd>
            </dl>
            <dl>
              <dt>4,500<span>Tons</span></dt>
              <dd>Wheat processed per day</dd>
            </dl>
            <dl>
              <dt>7</dt>
              <dd>Automated 1000-type noodle lines</dd>
            </dl>
            <dl>
              <dt>200,000<span>Tons</span></dt>
              <dd>Own grain storage capacity</dd>
            </dl>
            <dl>
              <dt>6</dt>
              <dd>Production bases across 3 provinces</dd>
            </dl>
            <dl>
              <dt>30<span>+</span></dt>
              <dd>Years of food manufacturing</dd>
            </dl>
          </div>
        </div>
      </section>

      <ContactCta
        kicker="Start your OEM project"
        title="Send us your product idea — get a manufacturing proposal."
        text="Tell us your target market, preferred formats and estimated volume. Our export team replies with samples direction, specifications and a practical quotation path."
        buttonLabel="Request a Quote"
        buttonHref="/contact/"
      />
    </main>

    <Footer showCta={false} />
    <script src="/scripts/site.js" defer></script>
  </body>
</html>
