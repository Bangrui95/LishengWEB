---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import HeroSlider from "../components/HeroSlider.astro";
import "../styles/global.css";
import "../styles/index.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Private Label & OEM Noodle Manufacturer in China</title>
    <meta
      name="description"
      content="OEM and private label noodle manufacturing for global food brands, importers, and distributors."
    />
  </head>
  <body>
    <Header />
    <main>
      <HeroSlider />
      <section class="company-overview" aria-labelledby="company-overview-title">
        <div class="overview-copy">
          <h2 id="company-overview-title">
            Export-ready noodle manufacturing for global food brands
          </h2>
          <p>
            Lisheng supports overseas importers, private label brands, and
            foodservice distributors with custom noodle production, flexible
            packaging, and reliable supply for international markets.
          </p>
        </div>

        <div class="overview-stats">
          <img
            src="/images/main/3.jpg"
            alt="Noodle production and supply background"
          />
          <div class="overview-stats-overlay"></div>
          <dl class="stats-list">
            <div class="stat-item">
              <dt>OEM</dt>
              <dd>private label production</dd>
            </div>
            <div class="stat-item">
              <dt>4+</dt>
              <dd>core noodle categories</dd>
            </div>
            <div class="stat-item">
              <dt>Global</dt>
              <dd>export-ready supply support</dd>
            </div>
          </dl>
        </div>
      </section>

      <section class="featured-links" aria-labelledby="featured-links-title">
        <h2 id="featured-links-title" class="sr-only">Featured company links</h2>

        <article class="featured-report">
          <div class="report-image">
            <img src="/images/main/4.jpg" alt="OEM noodle packaging and product display" />
          </div>
          <div class="report-copy">
            <h3>OEM Noodle Manufacturing Guide</h3>
            <p>
              Explore our private label capabilities, product customization,
              packaging support, and export-ready manufacturing process.
            </p>
            <a href="/oem-private-label-noodles/">Read & Download</a>
          </div>
        </article>

        <div class="feature-card-grid">
          <article class="feature-card">
            <img src="/images/main/1.jpg" alt="Lisheng noodle manufacturing company overview" />
            <div class="feature-card-copy">
              <h3>Who we are</h3>
              <p>
                A noodle manufacturing partner supporting overseas importers,
                retail food brands, and foodservice distributors.
              </p>
              <a href="/about/">Find out more</a>
            </div>
          </article>

          <article class="feature-card">
            <img src="/images/main/2.jpg" alt="Custom noodle products and services" />
            <div class="feature-card-copy">
              <h3>Products & Services</h3>
              <p>
                Custom instant noodles, dry noodles, ramen, packaging options,
                and OEM production support for global markets.
              </p>
              <a href="/products/">Find out more</a>
            </div>
          </article>
        </div>
      </section>

      <section class="about-section" aria-labelledby="about-section-title">
        <div class="about-inner">
          <div class="about-media">
            <img src="/images/main/1.jpg" alt="Lisheng manufacturing and export capability" />
            <a class="about-play" href="/about/" aria-label="Learn more about Lisheng">▶</a>
          </div>

          <div class="about-copy">
            <h2 id="about-section-title">About us</h2>
            <p>
              Lisheng is focused on noodle manufacturing for overseas brands,
              importers, and foodservice partners. We support private label
              production, custom packaging, product specification development,
              and export-ready supply for international markets.
            </p>
            <p>
              From instant noodles and dry noodles to ramen-style products and
              bulk foodservice supply, our team helps buyers turn market needs
              into stable, scalable noodle products.
            </p>
            <a class="about-more" href="/about/">More <span aria-hidden="true">→</span></a>
          </div>

          <div class="about-gallery" aria-label="Company and production gallery">
            <img src="/images/main/2.jpg" alt="Noodle product and packaging detail" />
            <img src="/images/main/3.jpg" alt="Production and supply chain scene" />
            <img src="/images/main/4.jpg" alt="Export-ready noodle product display" />
            <img src="/images/main/1.jpg" alt="Lisheng production overview" />
          </div>
        </div>
      </section>

      <section class="products-section" aria-labelledby="products-section-title">
        <div class="products-inner">
          <div class="section-heading">
            <h2 id="products-section-title">Products</h2>
          </div>

          <div class="product-tabs" role="tablist" aria-label="Product categories">
            <button class="active" type="button" role="tab" aria-selected="true" data-product-tab="instant">
              Instant Noodles
            </button>
            <button type="button" role="tab" aria-selected="false" data-product-tab="dry">
              Dry Noodles
            </button>
            <button type="button" role="tab" aria-selected="false" data-product-tab="ramen">
              Ramen Noodles
            </button>
            <button type="button" role="tab" aria-selected="false" data-product-tab="foodservice">
              Foodservice Bulk
            </button>
          </div>

          <div class="product-panels">
            <div class="product-panel active" data-product-panel="instant">
              <article class="product-card">
                <img src="/images/main/1.jpg" alt="Private label instant noodle bowl" />
                <h3>Private Label Instant Noodles</h3>
              </article>
              <article class="product-card">
                <img src="/images/main/2.jpg" alt="Cup instant noodle product" />
                <h3>Cup & Bowl Instant Noodles</h3>
              </article>
              <article class="product-card">
                <img src="/images/main/3.jpg" alt="Custom instant noodle flavor" />
                <h3>Custom Flavor Development</h3>
              </article>
              <article class="product-card">
                <img src="/images/main/4.jpg" alt="Export instant noodle packaging" />
                <h3>Export-Ready Retail Packaging</h3>
              </article>
            </div>

            <div class="product-panel" data-product-panel="dry" hidden>
              <article class="product-card">
                <img src="/images/main/1.jpg" alt="Bulk dry noodle supply" />
                <h3>Bulk Dry Noodle Supply</h3>
              </article>
              <article class="product-card">
                <img src="/images/main/2.jpg" alt="Private label dry noodles" />
                <h3>Private Label Dry Noodles</h3>
              </article>
              <article class="product-card">
                <img src="/images/main/3.jpg" alt="Retail dry noodle pack" />
                <h3>Retail Pack Dry Noodles</h3>
              </article>
              <article class="product-card">
                <img src="/images/main/4.jpg" alt="Food export dry noodles" />
                <h3>Export Specification Noodles</h3>
              </article>
            </div>

            <div class="product-panel" data-product-panel="ramen" hidden>
              <article class="product-card">
                <img src="/images/main/1.jpg" alt="Ramen style noodle OEM product" />
                <h3>Ramen-Style OEM Noodles</h3>
              </article>
              <article class="product-card">
                <img src="/images/main/2.jpg" alt="Custom ramen noodle formula" />
                <h3>Custom Ramen Formulas</h3>
              </article>
              <article class="product-card">
                <img src="/images/main/3.jpg" alt="Ramen noodle private label pack" />
                <h3>Private Label Ramen Packs</h3>
              </article>
              <article class="product-card">
                <img src="/images/main/4.jpg" alt="Ramen products for overseas markets" />
                <h3>Ramen for Overseas Markets</h3>
              </article>
            </div>

            <div class="product-panel" data-product-panel="foodservice" hidden>
              <article class="product-card">
                <img src="/images/main/1.jpg" alt="Foodservice bulk noodle supply" />
                <h3>Foodservice Bulk Noodles</h3>
              </article>
              <article class="product-card">
                <img src="/images/main/2.jpg" alt="Restaurant noodle supply program" />
                <h3>Restaurant Supply Programs</h3>
              </article>
              <article class="product-card">
                <img src="/images/main/3.jpg" alt="Distributor noodle pack" />
                <h3>Distributor Pack Options</h3>
              </article>
              <article class="product-card">
                <img src="/images/main/4.jpg" alt="Wholesale noodle manufacturing" />
                <h3>Wholesale Noodle Manufacturing</h3>
              </article>
            </div>
          </div>

          <a class="products-more" href="/products/">See more <span aria-hidden="true">→</span></a>
        </div>
      </section>

      <section class="history-section" aria-labelledby="history-section-title">
        <div class="history-inner">
          <div class="section-heading">
            <h2 id="history-section-title">History</h2>
          </div>

          <div class="history-scroll" aria-label="Company development timeline from 1995 to 2026">
            <ol class="history-track">
              <li class="history-item">
                <time datetime="1995">1995</time>
                <span></span>
                <p>Company roots established with a focus on noodle and food manufacturing.</p>
              </li>
              <li class="history-item">
                <time datetime="2002">2002</time>
                <span></span>
                <p>Production capabilities expanded to support stable regional supply.</p>
              </li>
              <li class="history-item">
                <time datetime="2008">2008</time>
                <span></span>
                <p>Private label production support began for customized noodle products.</p>
              </li>
              <li class="history-item">
                <time datetime="2015">2015</time>
                <span></span>
                <p>Packaging options and product specifications developed for overseas buyers.</p>
              </li>
              <li class="history-item">
                <time datetime="2020">2020</time>
                <span></span>
                <p>OEM services expanded across instant noodles, dry noodles, and ramen-style products.</p>
              </li>
              <li class="history-item">
                <time datetime="2023">2023</time>
                <span></span>
                <p>Export-ready supply processes refined for brands, importers, and distributors.</p>
              </li>
              <li class="history-item">
                <time datetime="2026">2026</time>
                <span></span>
                <p>Continuing to build a global OEM noodle manufacturing platform.</p>
              </li>
            </ol>
          </div>
        </div>
      </section>

      <section class="brands-section" aria-labelledby="brands-section-title">
        <div class="brands-inner">
          <h2 id="brands-section-title">Our Brands</h2>
          <p>
            We support a growing range of noodle and private label product
            programs for overseas buyers. Our brand and packaging capabilities
            help customers develop retail-ready products with consistent
            quality, reliable supply, and market-ready presentation.
          </p>
        </div>

        <div class="brand-marquee" aria-label="Brand logo carousel">
          <div class="brand-track">
            <div class="brand-tile">
              <img src="/images/main/1.jpg" alt="Brand placeholder 1" />
            </div>
            <div class="brand-tile">
              <img src="/images/main/2.jpg" alt="Brand placeholder 2" />
            </div>
            <div class="brand-tile">
              <img src="/images/main/3.jpg" alt="Brand placeholder 3" />
            </div>
            <div class="brand-tile">
              <img src="/images/main/4.jpg" alt="Brand placeholder 4" />
            </div>
            <div class="brand-tile">
              <img src="/images/main/1.jpg" alt="Brand placeholder 1" />
            </div>
            <div class="brand-tile">
              <img src="/images/main/2.jpg" alt="Brand placeholder 2" />
            </div>
            <div class="brand-tile">
              <img src="/images/main/3.jpg" alt="Brand placeholder 3" />
            </div>
            <div class="brand-tile">
              <img src="/images/main/4.jpg" alt="Brand placeholder 4" />
            </div>
          </div>
        </div>
      </section>

      <section class="world-section" aria-labelledby="world-section-title">
        <div class="world-header">
          <h2 id="world-section-title">Around the world</h2>
          <p>
            Building export-ready noodle supply for overseas brands, importers,
            distributors, and foodservice customers across global markets.
          </p>
          <ul class="world-legend" aria-label="Export capability legend">
            <li><span class="legend-dot export"></span>Export markets</li>
            <li><span class="legend-dot oem"></span>OEM programs</li>
            <li><span class="legend-dot supply"></span>Supply partners</li>
          </ul>
        </div>

        <div class="world-map-panel">
          <img src="/images/icon/map.png" alt="World map showing global market coverage" />
        </div>
      </section>

      <section class="news-section" aria-labelledby="news-section-title">
        <div class="news-inner">
          <div class="section-heading">
            <h2 id="news-section-title">News</h2>
          </div>

          <div class="news-layout">
            <article class="news-featured">
              <img src="/images/main/4.jpg" alt="Private label noodle product news" />
              <div class="news-featured-copy">
                <h3>New OEM noodle packaging options for overseas brands</h3>
                <time datetime="2026-06-08">2026-06-08</time>
                <p>
                  Lisheng continues to expand packaging options for private
                  label noodle programs, supporting retail, foodservice, and
                  importer-led product development.
                </p>
              </div>
            </article>

            <div class="news-list">
              <article class="news-item">
                <h3>
                  <a href="/blog/oem-noodle-sampling-process/">
                    OEM noodle sampling process for new buyers
                  </a>
                </h3>
                <time datetime="2026-05-20">2026-05-20</time>
                <p>
                  A practical look at how product samples, packaging direction,
                  and target market requirements move into production.
                </p>
              </article>

              <article class="news-item">
                <h3>
                  <a href="/blog/private-label-noodle-packaging/">
                    Private label packaging support for noodle products
                  </a>
                </h3>
                <time datetime="2026-04-18">2026-04-18</time>
                <p>
                  Flexible packaging formats help brands match shelf position,
                  foodservice needs, and regional purchasing habits.
                </p>
              </article>

              <article class="news-item">
                <h3>
                  <a href="/blog/export-ready-noodle-manufacturing/">
                    Export-ready manufacturing for noodle supply programs
                  </a>
                </h3>
                <time datetime="2026-03-26">2026-03-26</time>
                <p>
                  Stable specifications, clear communication, and reliable
                  supply planning are essential for overseas noodle programs.
                </p>
              </article>
            </div>
          </div>

          <a class="news-more" href="/blog/">See more <span aria-hidden="true">→</span></a>
        </div>
      </section>
    </main>

    <Footer />
    <script src="/scripts/site.js" defer></script>
  </body>
</html>
