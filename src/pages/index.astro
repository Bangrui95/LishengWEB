      <section class="world-section" aria-labelledby="world-section-title">
        <div class="world-inner">
          <div class="section-heading">
            <h2 id="world-section-title">Around the world</h2>
          </div>

          <p class="world-intro">
            Building export-ready noodle supply for overseas brands, importers,
            distributors, and foodservice customers across global markets.
          </p>

          <ul class="world-legend" aria-label="Export capability legend">
            <li><span class="legend-dot export"></span>Export markets</li>
            <li><span class="legend-dot oem"></span>OEM programs</li>
            <li><span class="legend-dot supply"></span>Supply partners</li>
          </ul>

          <div class="world-map-panel">
            <img
              src="/images/icon/map.png"
              alt="World map showing global market coverage"
            />
          </div>
        </div>
      </section>

      <section class="news-section" aria-labelledby="news-section-title">
        <div class="news-inner">
          <div class="section-heading">
            <h2 id="news-section-title">News</h2>
          </div>

          <div class="news-layout">
            <article class="news-featured">
              <img
                src="/images/news/news-567.jpg"
                alt="Lisheng stone-milled whole wheat flour series"
              />
              <div class="news-featured-copy">
                <h3>Lisheng Whole Wheat Flour Series: A Healthier Way to Eat</h3>
                <p>
                  Our dedicated whole grain workshop uses Danish stone mills
                  with low-temperature grinding and a bran-baking process —
                  keeping the bran, germ and endosperm intact for whole wheat
                  flour and noodle products.
                </p>
              </div>
            </article>

            <div class="news-list">
              <article class="news-item">
                <h3>
                  <a href="/news/">
                    New Lisheng products hit the market
                  </a>
                </h3>
                <p>
                  Liangshan Lisheng now mills 3,000 tons of wheat daily on a
                  full Bühler intelligent production system with complete
                  flour blending.
                </p>
              </article>

              <article class="news-item">
                <h3>
                  <a href="/news/">
                    Capacity doubling: 3,000-ton milling project signed in
                    Liangshan
                  </a>
                </h3>
                <p>
                  Lisheng signed the agreement for a 3,000-ton-per-day flour
                  processing project in Liangshan County — a major growth
                  milestone for the group.
                </p>
              </article>

              <article class="news-item">
                <h3>
                  <a href="/news/">
                    300-ton premium noodle expansion passes acceptance review
                  </a>
                </h3>
                <p>
                  The expansion project for premium dried noodles, noodle
                  sheets and non-fried instant noodles passed its acceptance
                  review, lifting daily noodle output by 300 tons.
                </p>
              </article>
            </div>
          </div>

          <a class="news-more" href="/news/">
            See more <span aria-hidden="true">→</span>
          </a>
        </div>
      </section>
    </main>

    <Footer />
    <script src="/scripts/site.js" defer></script>
  </body>
</html>
