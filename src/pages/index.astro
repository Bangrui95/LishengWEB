---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import HeroSlider from "../components/HeroSlider.astro";
import "../styles/global.css";
import "../styles/index.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Private Label & OEM Noodle Manufacturer in China</title>
    <meta
      name="description"
      content="OEM and private label noodle manufacturing for global food brands, importers, and distributors."
    />
  </head>
  <body>
    <Header />
    <main>
      <HeroSlider />
      <section class="company-overview" aria-labelledby="company-overview-title">
        <div class="overview-copy">
          <h2 id="company-overview-title">
            Export-ready noodle manufacturing<br />
            for global food brands
          </h2>
          <p>
            Lisheng provides overseas importers, private-label brands and foodservice distributors with customised noodle and flour production, in-house packaging support and reliable supply for international markets.</p>
        </div>

        <div class="overview-stats">
          <div class="stats-row stats-row-primary">
            <dl class="stat-item">
              <dt>
                <span class="stat-number" aria-label="30+">
                  <span class="stat-digit" aria-hidden="true">3</span>
                  <span class="stat-digit" aria-hidden="true">0</span>
                  <span class="stat-symbol" aria-hidden="true">+</span>
                </span>
              </dt>
              <dd>Years of Food Manufacturing Experience</dd>
            </dl>
            <dl class="stat-item">
              <dt>
                <span class="stat-number" aria-label="20+">
                  <span class="stat-digit" aria-hidden="true">2</span>
                  <span class="stat-digit" aria-hidden="true">0</span>
                  <span class="stat-symbol" aria-hidden="true">+</span>
                </span>
              </dt>
              <dd>Product Lines & Custom Manufacturing</dd>
            </dl>
            <dl class="stat-item">
              <dt>
                <span class="stat-number" aria-label="6+">
                  <span class="stat-digit" aria-hidden="true">6</span>
                  <span class="stat-symbol" aria-hidden="true">+</span>
                </span>
              </dt>
              <dd>Export Markets</dd>
            </dl>
          </div>

          <div class="stats-row stats-row-secondary">
            <dl class="stat-item">
              <dt>
                <span class="stat-number" aria-label="3">
                  <span class="stat-digit" aria-hidden="true">3</span>
                </span>
                <span class="stat-unit">Billion</span>
              </dt>
              <dd>Annual Revenue</dd>
            </dl>
            <dl class="stat-item">
              <dt>
                <span class="stat-number" aria-label="4,500">
                  <span class="stat-digit" aria-hidden="true">4</span>
                  <span class="stat-comma" aria-hidden="true">,</span>
                  <span class="stat-digit" aria-hidden="true">5</span>
                  <span class="stat-digit" aria-hidden="true">0</span>
                  <span class="stat-digit" aria-hidden="true">0</span>
                </span>
                <span class="stat-unit">Tons</span>
              </dt>
              <dd>Daily Wheat Processing Capacity</dd>
            </dl>
            <dl class="stat-item">
              <dt>
                <span class="stat-number" aria-label="600">
                  <span class="stat-digit" aria-hidden="true">6</span>
                  <span class="stat-digit" aria-hidden="true">0</span>
                  <span class="stat-digit" aria-hidden="true">0</span>
                </span>
                <span class="stat-unit">Tons</span>
              </dt>
              <dd>Daily Noodle Production Capacity</dd>
            </dl>
          </div>
        </div>
      </section>

      <section class="featured-links" aria-labelledby="featured-links-title">
        <h2 id="featured-links-title" class="sr-only">Featured company links</h2>

        <article class="featured-report">
          <div class="report-image">
            <img
              src="/images/main/OEM.png"
              alt="OEM noodle packaging and product display"
            />
          </div>
          <div class="report-copy">
            <h3>OEM & Private Label Supply</h3>
            <p>
              Custom noodle and flour manufacturing for overseas importers, retail brands and foodservice distributors, with support for product specifications, packaging formats and export-ready supply.</p>
            <div class="report-actions" aria-label="OEM guide links">
              <a class="report-action" href="/services/">
                <span>OEM Manufacturing Guide</span>
                <span aria-hidden="true">→</span>
              </a>
              <a class="report-action" href="/services/customization/">
                <span>Product Customization</span>
                <span aria-hidden="true">→</span>
              </a>
              <a class="report-action" href="/contact/">
                <span>Start an OEM Project</span>
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        </article>

        <div class="feature-card-grid">
          <article class="feature-card">
            <img
              src="/images/main/WHO.png"
              alt="Lisheng noodle manufacturing company overview"
            />
            <div class="feature-card-copy">
              <h3>Manufacturing Capability</h3>
              <p>
                An integrated production system covering wheat processing, noodle manufacturing, packaging and logistics, built to support stable quality, scalable output and long-term supply.</p>
              <a href="/company/">Find out more</a>
            </div>
          </article>

          <article class="feature-card">
            <img
              src="/images/main/products.png"
              alt="Custom noodle products and services"
            />
            <div class="feature-card-copy">
              <h3>Product Range</h3>
              <p>
                From noodles to wheat flour and private-label packaging, Lisheng develops product lines that can be adapted for retail, foodservice and export channels. Each product can be adjusted around market needs.</p>
              <a href="/products/">Find out more</a>
            </div>
          </article>
        </div>
      </section>

      <section class="about-section" aria-labelledby="about-section-title">
        <div class="about-inner">
          <div class="about-left-panel">
            <div class="about-media">
              <img
                src="/images/icon/logo.png"
                alt="Lisheng Group logo"
              />
            </div>

            <div class="subsidiary-list" aria-label="Lisheng Group subsidiaries">
              <h2>Group Subsidiaries</h2>
              <ul>
                <li>Shandong Lisheng Food Group</li>
                <li>Shandong Lisheng Group Chengwu Food</li>
                <li>Shandong Lisheng Group Wenshang Flour Industry</li>
                <li>Shandong Lisheng Group Shenzhou Flour</li>
                <li>Henan Lisheng Flour Industry</li>
                <li>Liangshan Lisheng Food</li>
                <li>Shandong Ruili Food Technology</li>
                <li>Jining Tianyu Color Printing & Packaging</li>
              </ul>
            </div>
          </div>

          <div class="about-copy">
            <h2 id="about-section-title">About us</h2>
            <p>
              Shandong Lisheng Group was founded in 1995 and is located in
              Jining High-tech Industrial Development Zone, Shandong Province.
              Lisheng Group has always upheld its corporate mission of
              “building a business that benefits people’s everyday lives”. By
              making full use of its strengths in quality, scale, integrity,
              brand value and service, the Group is committed to developing
              itself into a large-scale food enterprise group with distinctive
              characteristics, strong technological capability and core
              competitiveness.
            </p>
            <p>
              The Group’s products are sold in more than 260 large and
              medium-sized cities across 30 provinces, municipalities and
              autonomous regions in China. Its dried noodle products are also
              exported to Southeast Asia, Europe and other international
              markets.
            </p>
            <p>
              The Group has six flour production bases, three dried noodle
              production workshops, and three grain storage companies. It has a
              daily wheat processing capacity of 7,000 tons, a daily dried
              noodle production capacity of 560 tons, and a grain storage
              capacity of 200,000 tons. It is a large-scale group enterprise
              integrating grain storage, processing, sales and logistics.
            </p>
            <a class="about-more" href="/company/">Find out more</a>
          </div>

          <div class="about-rd" aria-labelledby="about-rd-title">
            <div class="about-rd-main">
              <div class="about-rd-copy">
                <p>Research & product development</p>
                <h3 id="about-rd-title">R &amp; D Center</h3>
                <span>
                  Lisheng has an independent product development system covering
                  flour, dried noodles and related grain-based foods. With
                  experience across raw material testing, formula adjustment,
                  noodle texture development and packaging trials, the team
                  supports product improvement for different market needs.
                </span>
                <span>
                  The company also holds more than ten food production invention
                  patents, helping strengthen its long-term capability in
                  product innovation, process optimisation and stable industrial
                  production.
                </span>
                <a class="about-more" href="/factory/lab/">Find out more</a>
              </div>

              <div
                class="about-rd-media"
                aria-label="R&D and production development images"
              >
                <img
                  src="/images/factory/11.png"
                  alt="R&D specialist checking noodle product samples"
                />
                <img
                  src="/images/factory/22.png"
                  alt="R&D team reviewing product development details"
                />
                <img
                  src="/images/factory/33.png"
                  alt="Noodle product research and sample testing"
                />
              </div>

              <dl class="about-rd-points" aria-label="R&D capability highlights">
                <div>
                  <dt>Formula Development</dt>
                  <dd>
                    Testing and adjusting flour and dough formulas for different
                    product requirements
                  </dd>
                </div>
                <div>
                  <dt>Process Optimisation</dt>
                  <dd>
                    Improving production stability through our own patented food
                    processing technologies
                  </dd>
                </div>
                <div>
                  <dt>Product Standards</dt>
                  <dd>
                    Tested for food safety across multiple markets, supporting
                    retail, foodservice and export-grade specifications
                  </dd>
                </div>
              </dl>
            </div>

            <div class="about-factory" aria-labelledby="about-factory-title">
              <div
                class="about-factory-media"
                aria-label="Factory processing and automated production images"
              >
                <img
                  src="/images/factory/01.png"
                  alt="Automated factory processing line overview"
                />
                <img
                  src="/images/factory/02.png"
                  alt="Noodle processing machinery and production equipment"
                />
                <img
                  src="/images/factory/03.png"
                  alt="Factory machining and automated production system"
                />
              </div>

              <div class="about-factory-copy">
                <p>END-TO-END PRODUCTION</p>
                <h3 id="about-factory-title">
                  Manufacturing Strength
                </h3>
                <span>
                  Lisheng has built an integrated food production system
                  covering raw material sourcing, flour processing, noodle
                  manufacturing, packaging, storage, logistics and sales
                  support. This full-chain capability allows us to provide
                  stable quality, efficient production and reliable supply for
                  long-term partners.
                </span>
                <span>
                  For different market needs, we support customized noodle
                  specifications, including product size, texture, formulation,
                  packaging format and order requirements. With our own
                  packaging production resources, we can also provide flexible
                  packaging solutions for retail, foodservice, wholesale and
                  private-label products.
                </span>
                <a class="about-more" href="/factory/production/">Find out more</a>
              </div>

              <dl
                class="about-factory-stats"
                aria-label="Factory processing highlights"
              >
                <div>
                  <dt>Processing</dt>
                  <dd>
                    Integrated flour and noodle manufacturing with stable
                    production control
                  </dd>
                </div>
                <div>
                  <dt>Customisation</dt>
                  <dd>
                    Noodle size, texture, formulation and packaging options for
                    different markets
                  </dd>
                </div>
                <div>
                  <dt>Packaging</dt>
                  <dd>
                    In-house packaging support for retail, foodservice and
                    private-label products
                  </dd>
                </div>
              </dl>
            </div>
          </div>
        </div>
      </section>

      <section class="products-section" aria-labelledby="products-section-title">
        <div class="products-inner">
          <div class="section-heading">
            <h2 id="products-section-title">Products</h2>
          </div>

          <div
            class="product-tabs"
            role="tablist"
            aria-label="Product categories"
          >
            <button
              class="active"
              type="button"
              role="tab"
              aria-selected="true"
              data-product-tab="noodles"
            >
              Noodle Products
            </button>
            <button
              type="button"
              role="tab"
              aria-selected="false"
              data-product-tab="flour"
            >
              Flour Products
            </button>
            <button
              type="button"
              role="tab"
              aria-selected="false"
              data-product-tab="customization"
            >
              Custom Solutions
            </button>
          </div>

          <div class="product-panels">
            <div class="product-panel active" data-product-panel="noodles">
              <article class="product-card">
                <img
                  src="/images/products/noodles1/01.png"
                  alt="Noodle product series"
                />
                <h3>Noodle Product Series</h3>
              </article>
              <article class="product-card">
                <img
                  src="/images/products/noodles1/02.png"
                  alt="Packaged noodle products"
                />
                <h3>Packaged Noodle Products</h3>
              </article>
              <article class="product-card">
                <img
                  src="/images/products/noodles1/03.png"
                  alt="Retail noodle product range"
                />
                <h3>Retail Noodle Range</h3>
              </article>
              <article class="product-card">
                <img
                  src="/images/products/noodles1/04.png"
                  alt="Export noodle supply"
                />
                <h3>Export Noodle Supply</h3>
              </article>
            </div>

            <div class="product-panel" data-product-panel="flour" hidden>
              <article class="product-card">
                <img
                  src="/images/products/flour1/01.png"
                  alt="Wheat flour product"
                />
                <h3>Wheat Flour Products</h3>
              </article>
              <article class="product-card">
                <img
                  src="/images/products/flour1/02.png"
                  alt="Premium flour product"
                />
                <h3>Premium Flour Series</h3>
              </article>
              <article class="product-card">
                <img
                  src="/images/products/flour1/03.png"
                  alt="Food manufacturing flour"
                />
                <h3>Food Manufacturing Flour</h3>
              </article>
              <article class="product-card">
                <img
                  src="/images/products/flour1/04.png"
                  alt="Export-ready flour packaging"
                />
                <h3>Export Flour Packaging</h3>
              </article>
            </div>

            <div class="product-panel" data-product-panel="customization" hidden>
              <article class="product-card">
                <img
                  src="/images/products/customization1/01-shanghai-yangchun.webp"
                  alt="Shanghai Yangchun noodle customization"
                />
                <h3>Shanghai Yangchun Noodles</h3>
              </article>
              <article class="product-card">
                <img
                  src="/images/products/customization1/02-lanzhou-ramen.webp"
                  alt="Lanzhou lamian noodle customization"
                />
                <h3>Lanzhou Lamian Noodles</h3>
              </article>
              <article class="product-card">
                <img
                  src="/images/products/customization1/03-sichuan-dandan.webp"
                  alt="Sichuan dandan noodle customization"
                />
                <h3>Sichuan Dandan Noodles</h3>
              </article>
              <article class="product-card">
                <img
                  src="/images/products/customization1/04-shandong-ramen.webp"
                  alt="Shandong ramen noodle customization"
                />
                <h3>Shandong Ramen Noodles</h3>
              </article>
            </div>
          </div>

          <a class="products-more" href="/products/">
            See more <span aria-hidden="true">→</span>
          </a>
        </div>
      </section>

      <section class="history-section" aria-labelledby="history-section-title">
        <div class="history-inner">
          <div class="section-heading">
            <h2 id="history-section-title">History</h2>
          </div>

          <div class="history-carousel" data-history-carousel>
            <button
              class="history-nav history-nav-prev"
              type="button"
              data-history-prev
              aria-label="Show previous history items"
            >
              &lsaquo;
            </button>

            <div
              class="history-scroll"
              aria-label="Company development timeline from 1995 to today"
            >
              <ol class="history-track" data-history-track>
                <li class="history-item">
                  <time datetime="1995">1995</time>
                  <span></span>
                  <p>
                    Founded in Jining, Shandong, beginning with flour
                    processing and staple food manufacturing.
                  </p>
                </li>
                <li class="history-item">
                  <time datetime="2000">2000</time>
                  <span></span>
                  <p>
                    The Jining production base began operation, moving Lisheng
                    into standardised food manufacturing.
                  </p>
                </li>
                <li class="history-item">
                  <time datetime="2005">2005</time>
                  <span></span>
                  <p>
                    The Chengwu base expanded flour processing capacity in
                    southwest Shandong's key wheat region.
                  </p>
                </li>
                <li class="history-item">
                  <time datetime="2006">2006</time>
                  <span></span>
                  <p>
                    The Wenshang flour and noodle production base was
                    established and put into operation.
                  </p>
                </li>
                <li class="history-item">
                  <time datetime="2007">2007</time>
                  <span></span>
                  <p>
                    “Lisheng” wheat flour was named a China Top-Brand Product.
                  </p>
                </li>
                <li class="history-item">
                  <time datetime="2009">2009</time>
                  <span></span>
                  <p>
                    The Shenzhou flour base was established in Hebei, extending
                    production beyond Shandong.
                  </p>
                </li>
                <li class="history-item">
                  <time datetime="2011">2011</time>
                  <span></span>
                  <p>
                    The Lisheng trademark was recognised as a China Famous
                    Trademark.
                  </p>
                </li>
                <li class="history-item">
                  <time datetime="2016">2016</time>
                  <span></span>
                  <p>
                    Henan Lisheng was founded in Huaxian, a core county of
                    China's wheat heartland.
                  </p>
                </li>
                <li class="history-item">
                  <time datetime="2018">2018</time>
                  <span></span>
                  <p>
                    The Liangshan smart plant was established — a RMB 1 billion
                    project milling 3,000 tons of wheat daily.
                  </p>
                </li>
                <li class="history-item">
                  <time datetime="2020">2020</time>
                  <span></span>
                  <p>
                    Shandong Ruili Food Technology joined the group, extending
                    into frozen and deep-processed foods.
                  </p>
                </li>
                <li class="history-item">
                  <time datetime="2026">Today</time>
                  <span></span>
                  <p>
                    An integrated chain from wheat sourcing and milling to
                    export-ready OEM noodle supply.
                  </p>
                </li>
              </ol>
            </div>

            <button
              class="history-nav history-nav-next"
              type="button"
              data-history-next
              aria-label="Show next history items"
            >
              &rsaquo;
            </button>
          </div>
        </div>
      </section>

      <!-- Our Brands section hidden for now — uncomment to restore.
      <section class="brands-section" aria-labelledby="brands-section-title">
        <div class="brands-inner">
          <h2 id="brands-section-title">Our Brands</h2>
          <p>
            We support a growing range of noodle and private label product
            programs for overseas buyers. Our brand and packaging capabilities
            help customers develop retail-ready products with consistent
            quality, reliable supply, and market-ready presentation.
          </p>
        </div>

        <div class="brand-marquee" aria-label="Brand logo carousel">
          <div class="brand-track">
            <div class="brand-tile">
              <img src="/images/main/1.jpg" alt="Brand placeholder 1" />
            </div>
            <div class="brand-tile">
              <img src="/images/main/2.jpg" alt="Brand placeholder 2" />
            </div>
            <div class="brand-tile">
              <img src="/images/main/3.jpg" alt="Brand placeholder 3" />
            </div>
