              <img src="/images/main/1.jpg" alt="Brand placeholder 1" />
            </div>
            <div class="brand-tile">
              <img src="/images/main/2.jpg" alt="Brand placeholder 2" />
            </div>
            <div class="brand-tile">
              <img src="/images/main/3.jpg" alt="Brand placeholder 3" />
            </div>
            <div class="brand-tile">
              <img src="/images/main/4.jpg" alt="Brand placeholder 4" />
