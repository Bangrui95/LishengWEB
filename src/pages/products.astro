    <script src="/scripts/site.js" defer></script>

    <script>
      // Open the tab matching the URL hash (e.g. /products/#flour),
      // including when a dropdown link is clicked while already on this page.
      const activateFromHash = () => {
        const cat = location.hash.replace("#", "");
        if (!cat) return;
        const tab = document.querySelector(`[data-product-tab="${cat}"]`);
        if (tab instanceof HTMLElement) tab.click();
      };
      window.addEventListener("hashchange", activateFromHash);
      activateFromHash();
    </script>
