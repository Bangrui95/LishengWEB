---
const slides = [
  {
    image: "/images/main/11.webp",
    alt: "Lisheng Group brand image"
  },
  {
    image: "/images/main/22.png",
    alt: "Lisheng Group annual sales and production capacity image"
  },
  {
    image: "/images/main/33.png",
    alt: "Lisheng Group certifications and honors image"
  },
  {
    image: "/images/main/44.png",
    alt: "Lisheng Group retail food supply certification image"
  }
];
---

<section class="hero-slider" data-hero-slider>
  <div class="hero-track" data-hero-track>
    {slides.map((slide, index) => (
      <article class="hero-slide" aria-hidden={index === 0 ? "false" : "true"}>
        <img src={slide.image} alt={slide.alt} />
      </article>
    ))}
  </div>

  <div class="hero-controls" aria-label="Hero slider controls">
    <button type="button" data-slide-prev aria-label="Previous slide">‹</button>
    <div class="hero-dots">
      {slides.map((_, index) => (
        <button
          type="button"
          class={index === 0 ? "active" : ""}
          data-slide-to={index}
          aria-label={`Go to slide ${index + 1}`}
        ></button>
      ))}
    </div>
    <button type="button" data-slide-next aria-label="Next slide">›</button>
  </div>
</section>
