---
import "../styles/footer.css";

const { showCta = true } = Astro.props;
---

{showCta && (
  <section class="contact-cta" aria-labelledby="contact-cta-title">
    <div class="contact-cta-inner">
      <p>Ready for OEM noodle production?</p>
      <h2 id="contact-cta-title">
        Let’s build your <span>private label noodle program</span> together and
        move your supply chain forward.
      </h2>
      <a class="contact-cta-button" href="/contact/" aria-label="Contact Lisheng today">
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M21 3 10.8 13.2" />
          <path d="m21 3-6.5 18-3.7-7.8L3 9.5 21 3Z" />
        </svg>
        Contact us today
      </a>
    </div>
  </section>
)}

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <img src="/images/icon/logo-white.png" alt="Lisheng logo" />
      <p>
        Export-ready noodle manufacturing, private label production, and
        packaging support for global food brands, importers, and foodservice
        distributors.
      </p>
      <a class="footer-quote" href="/contact/">Request a Quote</a>
    </div>

    <nav class="footer-links" aria-label="Footer navigation">
      <div>
        <h2>Products</h2>
        <a href="/products/">Instant Noodles</a>
        <a href="/products/">Dry Noodles</a>
        <a href="/products/">Ramen Noodles</a>
        <a href="/products/">Foodservice Bulk</a>
      </div>

      <div>
        <h2>OEM Services</h2>
        <a href="/oem-private-label-noodles/">Private Label Manufacturing</a>
        <a href="/oem-private-label-noodles/">Custom Packaging</a>
        <a href="/oem-private-label-noodles/">Flavor Development</a>
        <a href="/manufacturing/">Export Support</a>
      </div>

      <div>
        <h2>Company</h2>
        <a href="/about/">About us</a>
        <a href="/manufacturing/">Manufacturing</a>
        <a href="/quality-certifications/">Quality</a>
        <a href="/blog/">News</a>
      </div>

      <div>
        <h2>Contact</h2>
        <a href="/contact/">Start an OEM Project</a>
        <a href="/contact/">Request Samples</a>
        <a href="/contact/">Packaging Consultation</a>
        <a href="/contact/">Export Supply Planning</a>
      </div>
    </nav>
  </div>

  <div class="footer-bottom">
    <p>© 2026 Lisheng. All rights reserved.</p>
    <div>
      <a href="/privacy/">Privacy Policy</a>
      <a href="/terms/">Terms</a>
      <a href="/contact/">Contact</a>
    </div>
  </div>
</footer>
