---
import ContactCta from "./ContactCta.astro";
import "../styles/footer.css";

const { showCta = true } = Astro.props;
---

{showCta && (
  <ContactCta
    secondaryLabel="Customize Your Product"
    secondaryHref="/services/customization/"
  />
)}

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <img src="/images/icon/logo-white.png" alt="Lisheng logo" />
      <p>
        Export-ready noodle manufacturing, private label production, and
        packaging support for global food brands, importers, and foodservice
        distributors.
      </p>
      <a class="footer-quote" href="/contact/">Request a Quote</a>
    </div>

    <nav class="footer-links" aria-label="Footer navigation">
      <div>
        <h2>Products</h2>
        <a href="/products/">Instant Noodles</a>
        <a href="/products/">Dry Noodles</a>
        <a href="/products/">Ramen Noodles</a>
        <a href="/products/">Foodservice Bulk</a>
      </div>

      <div>
        <h2>OEM Services</h2>
        <a href="/services/">Private Label Manufacturing</a>
        <a href="/services/customization/">Custom Packaging</a>
        <a href="/services/customization/">Flavor Development</a>
        <a href="/services/">Export Support</a>
      </div>

      <div>
        <h2>Company</h2>
        <a href="/company/">About us</a>
        <a href="/factory/production/">Manufacturing</a>
        <a href="/factory/certificates/">Quality</a>
        <a href="/news/">News</a>
      </div>

      <div>
        <h2>Contact</h2>
        <a href="/contact/">Start an OEM Project</a>
        <a href="/contact/">Request Samples</a>
        <a href="/contact/">Packaging Consultation</a>
        <a href="/contact/">Export Supply Planning</a>
      </div>
    </nav>
  </div>

  <div class="footer-bottom">
    <p>© 2026 Lisheng. All rights reserved.</p>
    <div>
      <a href="/privacy/">Privacy Policy</a>
      <a href="/terms/">Terms</a>
      <a href="/contact/">Contact</a>
    </div>
  </div>
</footer>
