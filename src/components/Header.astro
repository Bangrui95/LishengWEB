---
import "../styles/header.css";

const currentPath = Astro.url.pathname;
const navItems = [
  { href: "/", label: "Home" },
  {
    href: "/company/",
    label: "Company",
    children: [
      { href: "/company/", label: "About" },
      { href: "/company/honors/", label: "Honors & Awards" },
      { href: "/company/subsidiaries/", label: "Subsidiaries" }
    ]
  },
  {
    href: "/factory/production/",
    label: "Factory",
    children: [
      { href: "/factory/production/", label: "Smart Factory" },
      { href: "/factory/lab/", label: "Food Lab" },
      { href: "/factory/certificates/", label: "Product Certifications" },
      { href: "/factory/tour/", label: "Factory Tour" }
    ]
  },
  {
    href: "/services/",
    label: "Services",
    children: [
      { href: "/services/", label: "OEM Manufacturing" },
      { href: "/services/customization/", label: "Product Customization" }
    ]
  },
  {
    href: "/products/",
    label: "Products",
    children: [
      { href: "/products/#noodles", label: "Noodle Products" },
      { href: "/products/#flour", label: "Flour Products" },
      { href: "/products/#customization", label: "Partner Collaborations" },
      { href: "/products/specifications/", label: "Sample Specifications" }
    ]
  },
  { href: "/news/", label: "News" },
  { href: "/contact/", label: "Contact" }
];

const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
};

const isExactActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath === href.replace(/\/$/, "");
};

// Company and Factory share the /company/ path prefix, so dropdown parents
// highlight only when one of their own pages is open.
const navActive = (item: { href: string; children?: { href: string }[] }) =>
  item.children
    ? [item.href, ...item.children.map((c) => c.href.split("#")[0])].some(
        isExactActive
      )
    : isActive(item.href);
---

<header class="site-header" data-header>
  <a class="site-logo" href="/" aria-label="Home">
    <img src="/images/icon/logo-white.png" alt="Lisheng logo" />
  </a>

  <button class="nav-toggle" type="button" data-nav-toggle aria-label="Open navigation">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <nav class="site-nav" data-site-nav>
    {navItems.map((item) =>
      item.children ? (
        <div class={`nav-item has-dropdown ${navActive(item) ? "active" : ""}`}>
          <a
            href={item.href}
            class={navActive(item) ? "active" : ""}
            aria-haspopup="true"
          >
            {item.label}
          </a>
          <div class="nav-dropdown" aria-label={`${item.label} sections`}>
            {item.children.map((child) => (
              <a
                href={child.href}
                class={isExactActive(child.href) ? "active" : ""}
              >
                {child.label}
              </a>
            ))}
          </div>
        </div>
      ) : (
        <a href={item.href} class={isActive(item.href) ? "active" : ""}>
          {item.label}
        </a>
      )
    )}
  </nav>

  <a class="quote-link" href="/contact/">Request a Quote</a>

  <div class="nav-item has-dropdown lang-switch">
    <a href="#" aria-haspopup="true" aria-label="Language: English">EN</a>
    <div class="nav-dropdown" aria-label="Languages">
      <a href="#" data-lang="zh">中文</a>
    </div>
  </div>
</header>
