---
import "../styles/header.css";

const currentPath = Astro.url.pathname;
const navItems = [
  { href: "/", label: "Home" },
  { href: "/oem-private-label-noodles/", label: "OEM Services" },
  { href: "/products/", label: "Products" },
  { href: "/manufacturing/", label: "Manufacturing" },
  { href: "/quality-certifications/", label: "Quality" },
  { href: "/solutions/", label: "Solutions" },
  { href: "/contact/", label: "Contact" }
];

const isActive = (href) => {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
};
---

<header class="site-header" data-header>
  <a class="site-logo" href="/" aria-label="Home">
    <img src="/images/icon/logo-white.png" alt="Lisheng logo" />
  </a>

  <button class="nav-toggle" type="button" data-nav-toggle aria-label="Open navigation">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <nav class="site-nav" data-site-nav>
    {navItems.map((item) => (
      <a href={item.href} class={isActive(item.href) ? "active" : ""}>
        {item.label}
      </a>
    ))}
  </nav>

  <a class="quote-link" href="/contact/">Request a Quote</a>
</header>
